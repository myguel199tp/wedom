# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de datos (Postgres) ──────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=miniwallet
DB_PASSWORD=miniwallet
DB_NAME=miniwallet
# En un demo dejamos synchronize=true para que la BD se cree sola.
# En producción se pondría en false y se usarían migraciones.
DB_SYNCHRONIZE=true

# ─── JWT ───────────────────────────────────────────────
# Genera uno fuerte y único por entorno, p.ej.: openssl rand -base64 48
# NUNCA reutilices este valor de ejemplo en producción.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=24h

# URL del frontend para armar el enlace de recuperación de contraseña.
FRONTEND_URL=http://localhost:3001

# Orígenes permitidos para CORS (lista separada por comas).
# Si se omite, se usa FRONTEND_URL. Evita usar comodines en producción.
CORS_ORIGINS=http://localhost:3001

# ─── Reglas de negocio ─────────────────────────────────
# Saldo de prueba acreditado al registrarse (faucet de demo; no hay pasarela de recarga).
INITIAL_BALANCE_USD=5000
# Toda transferencia > a este monto (USD) pasa por validación de cumplimiento.
COMPLIANCE_THRESHOLD_USD=1000
# Anti-fraude: más de N transferencias por remitente en la ventana => sospechosa.
VELOCITY_MAX_TRANSFERS=5
VELOCITY_WINDOW_SECONDS=60

# Monto "muy superior": por encima de este umbral (USD) se marca aparte del
# umbral de cumplimiento (se sigue marcando LARGE_AMOUNT > 1000, y además
# VERY_LARGE_AMOUNT cuando supera este valor).
SUSPICIOUS_VERY_LARGE_AMOUNT_USD=3000

# Fragmentación (structuring): N o más envíos por debajo del umbral cuya suma
# supera el umbral, dentro de la ventana => reparto para evadir controles.
SUSPICIOUS_STRUCTURING_MIN_COUNT=3
SUSPICIOUS_STRUCTURING_WINDOW_SECONDS=3600

# Horario inusual: transferencias iniciadas muy de noche o muy de mañana.
# Franja [from, to) en hora local; soporta cruzar medianoche (p. ej. 22 -> 5).
SUSPICIOUS_ODD_HOURS_START=0
SUSPICIOUS_ODD_HOURS_END=5
# Zona horaria de negocio para evaluar el horario inusual.
SUSPICIOUS_TIMEZONE=America/Bogota

# ─── Correo (MailHog en local: sin credenciales reales) ─
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=MiniWallet <no-reply@miniwallet.local>

# ─── Bootstrap del administrador (seed) ────────────────
# Usa una contraseña fuerte y cámbiala tras el primer arranque.
ADMIN_EMAIL=admin@miniwallet.local
ADMIN_PASSWORD=cambia-esta-clave-de-admin
